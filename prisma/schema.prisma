generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// TENANT MANAGEMENT
// ============================================

model Tenant {
  id              String   @id @default(uuid())
  name            String
  subdomain       String   @unique
  matriculeFiscal String?
  vatNumber       String?
  address         String?
  city            String?
  zipCode         String?
  phone           String?
  email           String?
  logo            String?
  settings        Json     @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users             User[]
  modules           TenantModule[]
  products          Product[]
  clients           Client[]
  suppliers         Supplier[]
  invoices          Invoice[]
  purchaseOrders    PurchaseOrder[]
  accounts          AccountingAccount[]
  journalEntries    JournalEntry[]
  employees         Employee[]
  paySlips          PaySlip[]
  assets            Asset[]
  workOrders        WorkOrder[]
  workStations      WorkStation[]
  billsOfMaterials  BillOfMaterials[]
  productionOrders  ProductionOrder[]
  qualityControls   QualityControl[]
  costCenters       CostCenter[]
  costEntries       CostEntry[]
  accountingPeriods AccountingPeriod[]
  accountingJournals AccountingJournal[]
  qualifications    Qualification[]
  absences          Absence[]
  delays            Delay[]
  mutations          Mutation[]
  paieParameters    PaieParameters[]
  cashDrawer        CashDrawer?
  warehouses        Warehouse[]
  stockMovements    StockMovement[]
  posSessions       POSSession[]
  posOrders         POSOrder[]
  posPayments       POSPayment[]
  inventories       Inventory[]
  stockTransfers    StockTransfer[]
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      UserRole @default(USER)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

// ============================================
// MODULES
// ============================================

model Module {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  icon        String?
  monthlyPrice Decimal @default(0)
  isActive    Boolean  @default(true)
  tenants     TenantModule[]
  createdAt   DateTime @default(now())
}

model TenantModule {
  id        String   @id @default(uuid())
  tenantId  String
  moduleId  String
  isEnabled Boolean  @default(true)
  settings  Json     @default("{}")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  module    Module   @relation(fields: [moduleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, moduleId])
}

// ============================================
// MODULE: STOCK
// ============================================

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  code          String
  barcode       String?
  name          String
  description   String?
  category      String?
  unit          String   @default("unit")
  purchasePrice Decimal  @default(0)
  salePrice     Decimal  @default(0)
  vatRate       Decimal  @default(19)
  fodec         Boolean  @default(false)
  minStock      Decimal  @default(0)
  currentStock  Decimal  @default(0)
  images        String[] @default([])
  variants      Json    @default("[]")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements      StockMovement[]
  warehouseStock ProductWarehouse[]

  @@unique([tenantId, code])
}

model StockMovement {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      StockMovementType
  quantity  Decimal
  unitPrice Decimal?
  reference String?
  notes     String?
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId, productId])
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
}

// ============================================
// MODULE: WAREHOUSE
// ============================================

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String
  name      String
  address   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems   InventoryItem[]
  transfersFrom    StockTransfer[] @relation("TransferFrom")
  transfersTo      StockTransfer[] @relation("TransferTo")
  productStock     ProductWarehouse[]
  stockMovements   StockMovement[]
  inventories      Inventory[]

  @@unique([tenantId, code])
}

model ProductWarehouse {
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stock        Decimal   @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@id([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

// ============================================
// MODULE: INVENTORY
// ============================================

model Inventory {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  warehouseId String?
  warehouse   Warehouse?      @relation(fields: [warehouseId], references: [id])
  reference   String
  date        DateTime
  status      InventoryStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items InventoryItem[]

  @@unique([tenantId, reference])
  @@index([tenantId, warehouseId, status])
  @@index([tenantId, date])
}

enum InventoryStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

model InventoryItem {
  id          String    @id @default(uuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  productId   String
  expectedQty Decimal
  actualQty   Decimal
  unitCost    Decimal?
  variance    Decimal   @default(0)
  notes       String?
}

// ============================================
// MODULE: STOCK TRANSFER
// ============================================

model StockTransfer {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  reference       String
  date            DateTime
  fromWarehouseId String
  fromWarehouse    Warehouse       @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse       @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus  @default(DRAFT)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items StockTransferItem[]

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

enum TransferStatus {
  DRAFT
  IN_PROGRESS
  TRANSFERRED
  CANCELLED
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  quantity   Decimal
  notes      String?
}

// ============================================
// MODULE: COMMERCIAL
// ============================================

model Client {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  code            String
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  zipCode         String?
  country         String   @default("Tunisie")
  matriculeFiscal String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
}

model Supplier {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  code            String
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String   @default("Tunisie")
  matriculeFiscal String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
}

model Invoice {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  number       String
  type         DocumentType
  status       DocumentStatus @default(DRAFT)
  date         DateTime @default(now())
  dueDate      DateTime?

  subtotalHT   Decimal  @default(0)
  totalFodec   Decimal  @default(0)
  totalVAT     Decimal  @default(0)
  timbreFiscal Decimal  @default(1.000)
  totalTTC     Decimal  @default(0)
  vatSummary   Json?

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        InvoiceItem[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  description String
  unit        String   @default("EA")
  quantity    Decimal
  unitPriceHT Decimal
  discount    Decimal  @default(0)
  fodecApply  Boolean  @default(false)
  fodecAmount Decimal  @default(0)
  vatRate     Decimal  @default(19)
  vatAmount   Decimal  @default(0)
  totalHT     Decimal  @default(0)
  totalTTC    Decimal  @default(0)
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  number       String
  type         DocumentType
  status       DocumentStatus @default(DRAFT)
  date         DateTime @default(now())
  expectedDate DateTime?
  subtotal     Decimal  @default(0)
  taxRate      Decimal  @default(0)
  taxAmount    Decimal  @default(0)
  total        Decimal  @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PurchaseOrderItem[]

  @@unique([tenantId, number])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  description     String
  quantity        Decimal
  unitPrice       Decimal
  total           Decimal
}

enum DocumentType {
  INVOICE
  QUOTE
  ORDER
  DELIVERY_NOTE
  PURCHASE_ORDER
  PURCHASE_INVOICE
  CREDIT_NOTE
}

enum DocumentStatus {
  DRAFT
  PENDING
  CONFIRMED
  SENT
  PAID
  CANCELLED
}

// ============================================
// MODULE: POS
// ============================================

model CashDrawer {
  id          String   @id @default(uuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  balance     Decimal  @default(0)
  updatedAt   DateTime @updatedAt
}

model POSSession {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String
  userName    String
  openingCash Decimal
  closingCash Decimal?
  status      POSSessionStatus @default(OPEN)
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  notes       String?

  orders      POSOrder[]
}

enum POSSessionStatus {
  OPEN
  CLOSED
}

model POSOrder {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  sessionId       String
  session         POSSession @relation(fields: [sessionId], references: [id])
  orderNumber     String
  type            POSType @default(SALE)
  status          POSOrderStatus @default(CONFIRMED)
  clientId        String?
  clientName      String?
  subtotalHT      Decimal  @default(0)
  totalVAT        Decimal  @default(0)
  timbreFiscal    Decimal  @default(1)
  totalTTC        Decimal  @default(0)
  paidAmount      Decimal  @default(0)
  changeGiven     Decimal  @default(0)
  paymentMethod   PaymentMethod @default(CASH)
  isPaid          Boolean  @default(false)
  discountPercent Decimal  @default(0)
  discountAmount  Decimal  @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           POSOrderItem[]
  payments        POSPayment[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, sessionId])
}

enum POSType {
  SALE
  RETURN
}

enum POSOrderStatus {
  DRAFT
  CONFIRMED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  CHECK
  BANK_TRANSFER
  MIXED
}

model POSOrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       POSOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productCode String?
  description String
  quantity    Decimal
  unitPriceHT Decimal
  vatRate     Decimal  @default(19)
  vatAmount   Decimal  @default(0)
  discount    Decimal  @default(0)
  totalHT     Decimal  @default(0)
  totalTTC    Decimal  @default(0)
}

model POSPayment {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  orderId     String
  order       POSOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  amount      Decimal
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
}

// ============================================
// MODULE: COMPTABILITE
// ============================================

model AccountingAccount {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountNumber String
  name        String
  type        AccountType
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntryLines JournalEntryLine[]
  parent         AccountingAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       AccountingAccount[] @relation("AccountHierarchy")

  @@unique([tenantId, accountNumber])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model AccountingPeriod {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  startDate   DateTime
  endDate     DateTime
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntries JournalEntry[]

  @@unique([tenantId, name])
}

model AccountingJournal {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  type        JournalType
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     JournalEntry[]

  @@unique([tenantId, code])
}

enum JournalType {
  SALES
  PURCHASES
  BANK
  CASH
  GENERAL
  INVENTORY
}

model JournalEntry {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  journalId   String
  journal     AccountingJournal @relation(fields: [journalId], references: [id])
  periodId    String
  period      AccountingPeriod @relation(fields: [periodId], references: [id])
  entryNumber String
  date        DateTime
  description String
  reference   String?
  isPosted    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       JournalEntryLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId, journalId])
  @@index([tenantId, periodId])
}

model JournalEntryLine {
  id              String  @id @default(uuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account         AccountingAccount @relation(fields: [accountId], references: [id])
  debit           Decimal @default(0)
  credit          Decimal @default(0)
  description     String?
}

// ============================================
// MODULE: GRH & PAIE
// ============================================

model Qualification {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  code          String
  designation   String
  coefficient   Decimal  @default(1)
  salaryMin     Decimal  @default(0)
  salaryMax     Decimal  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees Employee[]

  @@unique([tenantId, code])
}

model Employee {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  employeeNumber    String
  firstName         String
  lastName          String
  email             String?
  phone             String?
  cin               String?
  birthDate         DateTime?
  birthPlace        String?
  nationality       String   @default("Tunisienne")
  genre             Genre    @default(MALE)
  etatCivil        EstadoCivil @default(CELIBATAIRE)
  enfantsCharge     Int      @default(0)
  situationFamiliale SituationFamiliale @default(NON_CHEF_FAMILLE)
  address           String?
  city              String?
  hireDate          DateTime
  departement       String?
  poste             String?
  qualificationId   String?
  qualification     Qualification? @relation(fields: [qualificationId], references: [id])
  typeContrat       TypeContrat @default(CDI)
  salary            Decimal   @default(0)
  modePaie          ModePaie  @default(VIREMENT)
  banque            String?
  compteBancaire    String?
  cnssNumber        String?
  cnrpsNumber       String?
  amoNumber         String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  absences    Absence[]
  delays      Delay[]
  mutations   Mutation[]
  paySlips    PaySlip[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, isActive])
}

enum Genre {
  MALE
  FEMALE
}
enum EstadoCivil {
  CELIBATAIRE
  MARIE
  DIVORCE
  VEUF
}
enum SituationFamiliale {
  CHEF_FAMILLE
  NON_CHEF_FAMILLE
}
enum TypeContrat {
  CDI
  CDD
  STAGE
  SAISONNIER
  INTERIM
}
enum ModePaie {
  VIREMENT
  CHEQUE
  ESPECE
}

model Absence {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  dateDebut     DateTime
  dateFin       DateTime
  type          TypeAbsence
  joursCal      Int
  joursOuvres   Int
  justifie      Boolean  @default(false)
  pieceJointe   String?
  montantRetenu Decimal  @default(0)
  statut        StatutAbsence @default(EN_ATTENTE)
  observations  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, employeeId])
  @@index([tenantId, statut])
}

enum TypeAbsence {
  MALADIE
  ACCIDENT_TRAVAIL
  CONGE_PAYE
  SANS_SOLDE
  MATERNITE
  PATERNITE
  AUTRE
}
enum StatutAbsence {
  EN_ATTENTE
  APPROUVE
  REJETE
}

model Delay {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  date          DateTime
  heureArrivee  String
  heureNormale  String   @default("08:00")
  minutesRetard Int      @default(0)
  justifie      Boolean  @default(false)
  motif         String?
  sanction      TypeSanction @default(AVERTISSEMENT)
  montantRetenu Decimal  @default(0)
  statut        StatutAbsence @default(EN_ATTENTE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, employeeId])
  @@index([tenantId, statut])
}

enum TypeSanction {
  RIEN
  AVERTISSEMENT
  RETENUE
}

model Mutation {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  type            TypeMutation
  ancienPoste     String?
  nouveauPoste    String?
  ancienDept      String?
  nouveauDept     String?
  ancienSalaire   Decimal  @default(0)
  nouveauSalaire  Decimal  @default(0)
  dateEffet       DateTime
  observations    String?
  statut          StatutAbsence @default(EN_ATTENTE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, employeeId])
}

enum TypeMutation {
  PROMOTION
  MUTATION
  RECLASSEMENT
  MISE_AU_REPOS
}

model PaieParameters {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  annee           Int      @default(2025)
  irppTranche1Max Decimal  @default(5000)
  irppTranche2Max Decimal  @default(10000)
  irppTranche3Max Decimal  @default(30000)
  irppTranche4Max Decimal  @default(50000)
  irppTaux1       Decimal  @default(0)
  irppTaux2       Decimal  @default(26)
  irppTaux3       Decimal  @default(32)
  irppTaux4       Decimal  @default(36)
  irppTaux5       Decimal  @default(40)
  cnavsPatronal   Decimal  @default(6.5)
  cnavsPlafond    Decimal  @default(10000)
  amoPatronal     Decimal  @default(2.5)
  tfpPatronal     Decimal  @default(1)
  fppsPatronal    Decimal  @default(0.4)
  cnrpsSalarial   Decimal  @default(4.75)
  cnssSalarial    Decimal  @default(1.5)
  cnavsSalarial   Decimal  @default(3.5)
  amoSalarial     Decimal  @default(0.75)
  cnrpsPlafond    Decimal  @default(10000)
  cnssPlafond     Decimal  @default(10000)
  cnavsPlafondSal Decimal  @default(10000)
  deductionChefFamille Decimal @default(150)
  deductionParEnfant   Decimal @default(40)
  enfantsMaxDeductible Int     @default(6)
  smigMensuel     Decimal  @default(469.4)
  heuresSup25     Decimal  @default(25)
  heuresSup50     Decimal  @default(50)
  heuresSup75     Decimal  @default(75)
  updatedAt       DateTime @updatedAt
}

model PaySlip {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  reference      String
  mois           Int
  annee          Int
  joursTravailles Int     @default(26)
  salaireBase    Decimal
  heuresSupQte   Decimal  @default(0)
  heuresSupMontant Decimal @default(0)
  primeAnciennete Decimal  @default(0)
  primeTransport  Decimal  @default(0)
  primePanier     Decimal  @default(0)
  autresPrimes    Decimal  @default(0)
  brutGlobal      Decimal
  cnrpsSalaire   Decimal  @default(0)
  cnssSalaire    Decimal  @default(0)
  cnavisSalaire  Decimal  @default(0)
  amoSalaire     Decimal  @default(0)
  totalCotisations Decimal @default(0)
  salaireImposable Decimal
  deductionChefFam Decimal @default(0)
  deductionEnfants Decimal @default(0)
  irpp           Decimal  @default(0)
  deductionAbsences Decimal @default(0)
  deductionRetards  Decimal @default(0)
  autresDeductions  Decimal @default(0)
  netAPayer      Decimal
  statut         PaymentStatus @default(PENDING)
  pdfUrl         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, employeeId])
  @@index([tenantId, annee, mois, statut])
  @@index([tenantId, annee, mois])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

// ============================================
// MODULE: GMAO
// ============================================

model Asset {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  description String?
  category    String?
  location    String?
  purchaseDate DateTime?
  purchaseCost Decimal?
  warrantyEnd DateTime?
  status      AssetStatus @default(ACTIVE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders  WorkOrder[]

  @@unique([tenantId, code])
}

enum AssetStatus {
  ACTIVE
  IN_MAINTENANCE
  BROKEN
  RETIRED
}

model WorkOrder {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  title       String
  description String?
  type        WorkOrderType
  priority    Priority @default(MEDIUM)
  status      WorkOrderStatus @default(OPEN)
  assignedTo  String?
  scheduledDate DateTime?
  completedDate DateTime?
  cost        Decimal?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
}
enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

// ============================================
// MODULE: GPAO
// ============================================

model WorkStation {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  description String?
  location    String?
  capacity    Decimal  @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productionOrders ProductionOrder[]

  @@unique([tenantId, code])
}

model BillOfMaterials {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  productId   String
  version     String   @default("1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       BillOfMaterialsItem[]

  @@unique([tenantId, productId, version])
}

model BillOfMaterialsItem {
  id                  String  @id @default(uuid())
  billOfMaterialsId   String
  billOfMaterials     BillOfMaterials @relation(fields: [billOfMaterialsId], references: [id], onDelete: Cascade)
  productId           String
  quantity            Decimal
}

model ProductionOrder {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  workStationId   String?
  workStation     WorkStation? @relation(fields: [workStationId], references: [id])
  productId       String
  quantity        Decimal
  status          ProductionStatus @default(PENDING)
  plannedStartDate DateTime?
  plannedEndDate  DateTime?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// MODULE: GQAO
// ============================================

model QualityControl {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  reference   String
  type        String
  status      QualityStatus @default(PENDING)
  inspectedItem String?
  quantity    Decimal?
  defects     Decimal?
  result      String?
  inspector   String?
  notes       String?
  controlledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
}

enum QualityStatus {
  PENDING
  PASSED
  FAILED
  UNDER_REVIEW
}

// ============================================
// MODULE: COMPTABILITE ANALYTIQUE
// ============================================

model CostCenter {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  type        CostCenterType
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  costEntries CostEntry[]

  @@unique([tenantId, code])
}

enum CostCenterType {
  PRODUCTION
  DISTRIBUTION
  ADMINISTRATION
  RESEARCH
}

model CostEntry {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  costCenterId String
  costCenter  CostCenter @relation(fields: [costCenterId], references: [id])
  description String
  amount      Decimal
  date        DateTime
  reference   String?
  createdAt   DateTime @default(now())
}
