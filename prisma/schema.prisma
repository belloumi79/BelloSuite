generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// TENANT MANAGEMENT (Multi-tenant)
// ============================================

model Tenant {
  id              String   @id @default(uuid())
  name            String
  subdomain       String   @unique
  matriculeFiscal String?  // Format: 1234567/A/M/000
  vatNumber       String?
  address         String?
  city            String?
  zipCode         String?
  phone           String?
  email           String?
  logo            String?
  settings        Json     @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users    User[]
  modules  TenantModule[]
  stock    StockMovement[]
  products Product[]
  clients  Client[]
  suppliers Supplier[]
  invoices Invoice[]
  purchaseOrders PurchaseOrder[]
  accounts AccountingAccount[]
  journalEntries JournalEntry[]
  employees Employee[]
  paySlips PaySlip[]
  assets Asset[]
  workOrders WorkOrder[]
  workStations WorkStation[]
  billsOfMaterials BillOfMaterials[]
  productionOrders ProductionOrder[]
  qualityControls QualityControl[]
  costCenters CostCenter[]
  costEntries CostEntry[]
  accountingPeriods AccountingPeriod[]
  accountingJournals AccountingJournal[]
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      UserRole @default(USER)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

// ============================================
// MODULES
// ============================================

model Module {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  icon        String?
  monthlyPrice Decimal @default(0)
  isActive    Boolean  @default(true)
  tenants     TenantModule[]
  createdAt   DateTime @default(now())
}

model TenantModule {
  id        String   @id @default(uuid())
  tenantId  String
  moduleId  String
  isEnabled Boolean  @default(true)
  settings  Json     @default("{}")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  module    Module   @relation(fields: [moduleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, moduleId])
}

// ============================================
// MODULE: STOCK (Gestion de Stocks)
// ============================================

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  code          String
  barcode       String?
  name          String
  description   String?
  category      String?
  unit          String   @default("unit")
  purchasePrice Decimal  @default(0)
  salePrice     Decimal  @default(0)
  vatRate       Decimal  @default(19) // Standard Tunisia: 19%
  fodec         Boolean  @default(false) // 1% tax
  minStock      Decimal  @default(0)
  currentStock  Decimal  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements   StockMovement[]

  @@unique([tenantId, code])
}

model StockMovement {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      StockMovementType
  quantity  Decimal
  unitPrice Decimal?
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([tenantId, productId])
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
}

// ============================================
// MODULE: COMMERCIAL
// ============================================

model Client {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  code            String
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  zipCode         String?
  country         String   @default("Tunisie")
  matriculeFiscal String?  // Format: 1234567/A/M/000
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        Invoice[]
  purchaseOrders  PurchaseOrder[]

  @@unique([tenantId, code])
}

model Supplier {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  code            String
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String   @default("Tunisie")
  matriculeFiscal String?  // Format: 1234567/A/M/000
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
}

model Invoice {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  number       String
  type         DocumentType
  status       DocumentStatus @default(DRAFT)
  date         DateTime @default(now())
  dueDate      DateTime?
  
  // Totals for Tunisia
  subtotalHT   Decimal  @default(0)
  totalFodec   Decimal  @default(0)
  totalVAT     Decimal  @default(0)
  timbreFiscal Decimal  @default(1.000) // Default 1 DT
  totalTTC     Decimal  @default(0)
  
  vatSummary   Json?    // Breakdown of VAT by rate for TEIF
  
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        InvoiceItem[]

  @@unique([tenantId, number])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  description String
  unit        String   @default("EA")
  quantity    Decimal
  unitPriceHT Decimal
  discount    Decimal  @default(0) // Percentage
  fodecApply  Boolean  @default(false)
  fodecAmount Decimal  @default(0)
  vatRate     Decimal  @default(19)
  vatAmount   Decimal  @default(0)
  totalHT     Decimal  @default(0)
  totalTTC    Decimal  @default(0)
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  number       String
  type         DocumentType
  status       DocumentStatus @default(DRAFT)
  date         DateTime @default(now())
  expectedDate DateTime?
  subtotal     Decimal  @default(0)
  taxRate      Decimal  @default(0)
  taxAmount    Decimal  @default(0)
  total        Decimal  @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PurchaseOrderItem[]

  @@unique([tenantId, number])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  description     String
  quantity        Decimal
  unitPrice       Decimal
  total           Decimal
}

enum DocumentType {
  INVOICE
  QUOTE
  ORDER
  DELIVERY_NOTE
  CREDIT_NOTE
}

enum DocumentStatus {
  DRAFT
  PENDING
  CONFIRMED
  SENT
  PAID
  CANCELLED
}

// ============================================
// MODULE: COMPTABILITÉ
// ============================================

model AccountingAccount {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountNumber String
  name        String
  type        AccountType
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntryLines JournalEntryLine[]
  parent         AccountingAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      AccountingAccount[] @relation("AccountHierarchy")

  @@unique([tenantId, accountNumber])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model AccountingPeriod {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String   // e.g. "Exercice 2026"
  startDate   DateTime
  endDate     DateTime
  isClosed    Boolean  @default(false) // Clôture de l'exercice
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntries JournalEntry[]

  @@unique([tenantId, name])
}

model AccountingJournal {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String   // e.g. ACH, VTE, ODi, BQ
  name        String
  type        JournalType
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     JournalEntry[]

  @@unique([tenantId, code])
}

enum JournalType {
  SALES
  PURCHASES
  BANK
  CASH
  GENERAL
  INVENTORY
}

model JournalEntry {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  journalId   String
  journal     AccountingJournal @relation(fields: [journalId], references: [id])
  periodId    String
  period      AccountingPeriod @relation(fields: [periodId], references: [id])
  entryNumber String
  date        DateTime
  description String
  reference   String? // Pièce justificative conforme au chemin d'audit
  isPosted    Boolean  @default(false) // Validation définitive (intangibilité)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       JournalEntryLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId, journalId])
  @@index([tenantId, periodId])
}

model JournalEntryLine {
  id              String  @id @default(uuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId       String
  account         AccountingAccount @relation(fields: [accountId], references: [id])
  debit           Decimal @default(0)
  credit          Decimal @default(0)
  description     String?
}

// ============================================
// MODULE: GRH & PAIE
// ============================================

model Employee {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employeeNumber String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  cin         String?
  birthDate   DateTime?
  hireDate    DateTime
  department  String?
  position    String?
  salary      Decimal?
  address     String?
  city        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paySlips    PaySlip[]

  @@unique([tenantId, employeeNumber])
}

model PaySlip {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  reference   String
  periodStart DateTime
  periodEnd   DateTime
  grossSalary Decimal
  socialSecurity Decimal @default(0)
  taxBase     Decimal
  incomeTax   Decimal @default(0)
  netSalary   Decimal
  paymentDate DateTime?
  status      PaymentStatus @default(PENDING)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, reference])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

// ============================================
// MODULE: GMAO (Maintenance)
// ============================================

model Asset {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  description String?
  category    String?
  location    String?
  purchaseDate DateTime?
  purchaseCost Decimal?
  warrantyEnd DateTime?
  status      AssetStatus @default(ACTIVE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders  WorkOrder[]

  @@unique([tenantId, code])
}

enum AssetStatus {
  ACTIVE
  IN_MAINTENANCE
  BROKEN
  RETIRED
}

model WorkOrder {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  title       String
  description String?
  type        WorkOrderType
  priority    Priority @default(MEDIUM)
  status      WorkOrderStatus @default(OPEN)
  assignedTo  String?
  scheduledDate DateTime?
  completedDate DateTime?
  cost        Decimal?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

// ============================================
// MODULE: GPAO (Production)
// ============================================

model WorkStation {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  description String?
  location    String?
  capacity    Decimal  @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productionOrders ProductionOrder[]

  @@unique([tenantId, code])
}

model BillOfMaterials {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  productId   String
  version     String   @default("1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       BillOfMaterialsItem[]

  @@unique([tenantId, productId, version])
}

model BillOfMaterialsItem {
  id                  String  @id @default(uuid())
  billOfMaterialsId   String
  billOfMaterials     BillOfMaterials @relation(fields: [billOfMaterialsId], references: [id], onDelete: Cascade)
  productId           String
  quantity            Decimal
}

model ProductionOrder {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  workStationId   String?
  workStation     WorkStation? @relation(fields: [workStationId], references: [id])
  productId       String
  quantity        Decimal
  status          ProductionStatus @default(PENDING)
  plannedStartDate DateTime?
  plannedEndDate  DateTime?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// MODULE: GQAO (Qualité)
// ============================================

model QualityControl {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  reference   String
  type        String
  status      QualityStatus @default(PENDING)
  inspectedItem String?
  quantity    Decimal?
  defects     Decimal?
  result      String?
  inspector   String?
  notes       String?
  controlledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, reference])
}

enum QualityStatus {
  PENDING
  PASSED
  FAILED
  UNDER_REVIEW
}

// ============================================
// MODULE: COMPTABILITÉ ANALYTIQUE
// ============================================

model CostCenter {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  type        CostCenterType
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  costEntries CostEntry[]

  @@unique([tenantId, code])
}

enum CostCenterType {
  PRODUCTION
  DISTRIBUTION
  ADMINISTRATION
  RESEARCH
}

model CostEntry {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  costCenterId String
  costCenter  CostCenter @relation(fields: [costCenterId], references: [id])
  description String
  amount      Decimal
  date        DateTime
  reference   String?
  createdAt   DateTime @default(now())
}
