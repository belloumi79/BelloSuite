{
  "version": 2,
  "functions": {
    "src/app/api/**/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "regions": ["fra1"],
  "env": {
    "NODE_ENV": "production"
  },
  "github": {
    "autoJobCancelation": true,
    "autoAlias": true,
    "silent": true
  },
  "buildCommand": "npm run vercel-build"
}